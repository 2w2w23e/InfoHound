INFOHOUND_ENV=development
INFOHOUND_DATABASE_URL=sqlite:///./data/infohound.db
INFOHOUND_SOURCE_CONFIG_PATH=backend/config/sources.yaml
INFOHOUND_RAW_STORAGE_PATH=./data/raw
INFOHOUND_EXPORT_PATH=./data/exports
INFOHOUND_DAILY_CRAWL_HOUR=2
INFOHOUND_DAILY_CRAWL_MINUTE=0
INFOHOUND_SCHEDULER_TIMEZONE=Asia/Shanghai
INFOHOUND_HTTP_TIMEOUT_SECONDS=20
INFOHOUND_HTTP_RETRY_COUNT=2
INFOHOUND_HTTP_RETRY_BACKOFF_SECONDS=1.0
INFOHOUND_SOURCE_TIMEOUT_SECONDS=180
INFOHOUND_MAX_LINKS_PER_SOURCE=30
